{
  "version": 2,
  "outputDirectory": "docs",
  "buildCommand": null,
  "installCommand": null,
  "framework": null,
  "builds": [
    { "src": "api/downloads.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/downloads", "dest": "/api/downloads.py" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
